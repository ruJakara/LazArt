      "id": "node-openrouter",
      "name": "OpenRouter — Llama 3 8B",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        304
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "openrouter-bearer",
          "name": "OpenRouter Bearer"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Parse the OpenRouter response and extract content\nconst response = $input.first().json;\n\n// Extract the message content from OpenRouter response structure\nconst rawContent = response?.choices?.[0]?.message?.content;\n\nif (!rawContent) {\n  throw new Error('No content in OpenRouter response: ' + JSON.stringify(response));\n}\n\n// Parse JSON (model should return strict JSON per system prompt)\nlet parsed;\ntry {\n  parsed = typeof rawContent === 'string' ? JSON.parse(rawContent) : rawContent;\n} catch (e) {\n  throw new Error('Failed to parse model JSON. Raw content: ' + rawContent);\n}\n\n// Validate required fields\nconst hook = parsed.hook || '';\nconst voiceover = parsed.voiceover || '';\nconst scenes = Array.isArray(parsed.scenes) ? parsed.scenes : [];\nconst hashtags = Array.isArray(parsed.hashtags) ? parsed.hashtags : [];\n\nreturn [{\n  json: {\n    hook,\n    voiceover,\n    scenes,\n    hashtags,\n    _meta: {\n      model: response?.model || 'meta-llama/llama-3-8b-instruct:free',\n      usage: response?.usage || null,\n      parsed_ok: true\n    }\n  }\n}];"
      },
      "id": "node-parse",
      "name": "Parse JSON Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        304
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "out-hook",
              "name": "hook",
              "value": "={{ $json.hook }}",
              "type": "string"
            },
            {
              "id": "out-voiceover",
              "name": "voiceover",
              "value": "={{ $json.voiceover }}",
              "type": "string"
            },
            {
              "id": "out-scenes",
              "name": "scenes",
              "value": "={{ $json.scenes }}",
              "type": "array"
            },
            {
              "id": "out-hashtags",
              "name": "hashtags",
              "value": "={{ $json.hashtags }}",
              "type": "array"
            },
            {
              "id": "out-model",
              "name": "model_used",
              "value": "={{ $json._meta.model }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "node-set",
